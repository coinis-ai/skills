#!/usr/bin/env bash
# Coinis skills — one-shot installer.
#
# What it does:
#   1. Clones (or updates) coinis-ltd/skills to ~/.coinis/skills/.
#   2. Auto-detects the agent host (Claude Code / Cursor / Codex).
#   3. Symlinks each coinis-* skill into the host's skills directory (Claude).
#   4. Verifies each linked skill's SKILL.md is readable through the symlink.
#   5. Prints manual plugin-manifest steps for Codex and Cursor.
#
# Usage:
#   curl -fsSL https://raw.githubusercontent.com/coinis-ltd/skills/main/setup | bash
#   ./setup [--host <claude|cursor|codex>]
#
# Env overrides:
#   COINIS_INSTALL_DIR   — clone target (default ~/.coinis/skills)
#   CLAUDE_SKILLS_DIR    — Claude skills dir (default ~/.claude/skills)

set -euo pipefail

REPO_URL="${COINIS_REPO_URL:-https://github.com/coinis-ltd/skills.git}"
INSTALL_DIR="${COINIS_INSTALL_DIR:-$HOME/.coinis/skills}"
CLAUDE_SKILLS_DIR="${CLAUDE_SKILLS_DIR:-$HOME/.claude/skills}"

# ─── Colors (degrade gracefully on pipes / dumb terminals) ───────────────
# Guard ANSI behind a real tty + tput capability check so that
# `curl … | bash` piped output is plain text, not garbled escapes.
if [ -t 1 ] && command -v tput >/dev/null 2>&1 && [ "$(tput colors 2>/dev/null || echo 0)" -ge 8 ]; then
  C_CYAN=$(tput setaf 6); C_YELLOW=$(tput setaf 3); C_RED=$(tput setaf 1)
  C_BOLD=$(tput bold); C_RESET=$(tput sgr0)
else
  C_CYAN=""; C_YELLOW=""; C_RED=""; C_BOLD=""; C_RESET=""
fi

say()  { printf '%s==>%s %s\n' "$C_CYAN" "$C_RESET" "$*"; }
warn() { printf '%s!!%s %s\n'  "$C_YELLOW" "$C_RESET" "$*" >&2; }
die()  { printf '%sxx%s %s\n'  "$C_RED" "$C_RESET" "$*" >&2; exit 1; }

# ─── Parse flags ─────────────────────────────────────────────────────────
HOST_OVERRIDE=""
while [ $# -gt 0 ]; do
  case "$1" in
    --host)
      shift
      [ $# -eq 0 ] && die "--host requires a value: claude | cursor | codex"
      HOST_OVERRIDE="$1"; shift ;;
    --host=*)
      HOST_OVERRIDE="${1#--host=}"; shift ;;
    --help|-h)
      cat <<'EOF'
Usage: ./setup [options]

Options:
  --host <agent>   Force install path for: claude, cursor, codex
                   (auto-detected if omitted)
  --help, -h       Show this message

Claude Code is the automated path (skills are symlinked). For Cursor and
Codex the script clones the repo and prints the plugin-manifest install
command rather than symlinking to an unverified skills path.
EOF
      exit 0 ;;
    *)
      warn "Unknown flag: $1"; shift ;;
  esac
done

command -v git >/dev/null 2>&1 || die "git is required but not installed."

# ─── Clone or update ─────────────────────────────────────────────────────
if [[ -d "$INSTALL_DIR/.git" ]]; then
  say "Updating $INSTALL_DIR"
  git -C "$INSTALL_DIR" pull --ff-only
else
  say "Cloning $REPO_URL → $INSTALL_DIR"
  mkdir -p "$(dirname "$INSTALL_DIR")"
  git clone --depth=1 "$REPO_URL" "$INSTALL_DIR"
fi

# ─── Print version ───────────────────────────────────────────────────────
VERSION="$(tr -d '[:space:]' < "$INSTALL_DIR/VERSION" 2>/dev/null || echo "unknown")"
echo
printf '%sCoinis Skills setup — v%s%s\n' "$C_BOLD" "$VERSION" "$C_RESET"
echo

# ─── Detect agent host ───────────────────────────────────────────────────
# Claude is the only automated (symlink) path. Cursor / Codex are routed to
# manual plugin-manifest install because their skills paths are unverified.
detect_host() {
  if [ -n "$HOST_OVERRIDE" ]; then echo "$HOST_OVERRIDE"; return; fi
  if [ -d "$HOME/.claude" ]; then echo "claude"; return; fi
  if [ -d "$HOME/.cursor" ]; then echo "cursor"; return; fi
  if [ -d "$HOME/.codex" ];  then echo "codex";  return; fi
  echo "unknown"
}

HOST="$(detect_host)"
case "$HOST" in
  claude|cursor|codex) ;;
  unknown)
    warn "Could not auto-detect an agent host (no ~/.claude, ~/.cursor, or ~/.codex)."
    HOST="claude"
    warn "Defaulting to Claude Code. Re-run with --host <claude|cursor|codex> to override." ;;
  *)
    die "Unknown host '$HOST'. Use one of: claude, cursor, codex." ;;
esac
say "Agent host: $HOST"

# ─── Link skills (Claude = automated symlink path) ───────────────────────
link_claude_skills() {
  mkdir -p "$CLAUDE_SKILLS_DIR"
  linked=0
  for skill_dir in "$INSTALL_DIR"/coinis-*/; do
    [[ -d "$skill_dir" ]] || continue
    name=$(basename "$skill_dir")
    src="${skill_dir%/}"
    target="$CLAUDE_SKILLS_DIR/$name"

    # 3-way branch: correct symlink → ok; stale symlink → relink; real file → warn.
    if [[ -L "$target" ]]; then
      current="$(readlink "$target")"
      if [[ "$current" == "$src" ]]; then
        :  # already correct
      else
        warn "$name: replacing stale symlink ($current → $src)"
        rm -f "$target"
        ln -s "$src" "$target"
        linked=$((linked + 1))
      fi
    elif [[ -e "$target" ]]; then
      warn "$name: $target exists and is not a symlink — leaving it alone."
    else
      ln -s "$src" "$target"
      linked=$((linked + 1))
    fi
  done
  say "Linked/relinked $linked skill(s) into $CLAUDE_SKILLS_DIR"

  # Post-install verify: SKILL.md must be readable through each symlink.
  fail=0
  for skill_dir in "$INSTALL_DIR"/coinis-*/; do
    [[ -d "$skill_dir" ]] || continue
    name=$(basename "$skill_dir")
    target="$CLAUDE_SKILLS_DIR/$name"
    [[ -L "$target" ]] || continue   # only verify what we manage as symlinks
    if [[ -r "$target/SKILL.md" ]]; then
      :  # readable
    else
      warn "$name: SKILL.md not readable through $target/SKILL.md"
      fail=1
    fi
  done
  if [[ "$fail" -ne 0 ]]; then
    die "Verification failed — one or more linked skills are not readable. See warnings above."
  fi
  say "Verified $(ls -d "$INSTALL_DIR"/coinis-*/ | wc -l | tr -d ' ') skill(s): SKILL.md readable through each symlink."
}

if [[ "$HOST" == "claude" ]]; then
  link_claude_skills
else
  warn "Skill symlinking is automated for Claude Code only."
  warn "For '$HOST', install via the plugin manifest (steps printed below)."
fi

# ─── Next steps ──────────────────────────────────────────────────────────
cat <<EOF

Coinis skills installed (v$VERSION).

Next steps:
  • Claude Code  — restart your client, then ask your agent "What Coinis skills are available?" to confirm.
  • Codex        — run \`/plugins install coinis-ltd/skills\`
  • Cursor       — run \`@plugins add coinis-ltd/skills\`

The clone lives at: $INSTALL_DIR

Prerequisites:
  • The Coinis MCP server (\`coinis\`) must be configured in your client (https://mcp.coinis.com).
  • You need a Coinis workspace with credits. Sign up at https://coinis.com.

Verify the install by asking your agent: "What Coinis skills are available?"
EOF
